# Web UI and local storage
UI_PORT=3000
RECEIVED_DIR=./received
LOG_FILE=./nexus.log
MAX_UPLOAD_BYTES=26214400
SOCKET_TIMEOUT=30000

# Hosted PHP directory service (default): HTTPS uses port 443.
AUTH_SERVER_URL=https://webgenie-ai.com/server.php
AUTH_PORT_UI=443
AUTH_USE_HTTP=1

# To use the included local PHP directory server instead, uncomment these lines.
# AUTH_HOST=127.0.0.1
# AUTH_PORT_UI=8000
# AUTH_USE_HTTP=0

# I2P router connection
I2P_SAM_HOST=127.0.0.1
I2P_SAM_PORT=7656
I2P_SOCKS_HOST=127.0.0.1
I2P_SOCKS_PORT=4447
LISTEN_PORT=9090

# Require manual approval for incoming transfers by default.
AUTO_ACCEPT=false